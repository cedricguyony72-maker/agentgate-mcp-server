{
  "name": "@agentgateeu/mcp-server",
  "version": "1.4.0",
  "description": "MCP server for AgentGate — submit and authorize AI payment requests from Claude Desktop",
  "type": "module",
  "bin": {
    "agentgate-mcp-server": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --target=node18 --format=esm --outfile=dist/index.js --banner:js='#!/usr/bin/env node'",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "esbuild": "^0.25.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": ["mcp", "agentgate", "payment", "ai", "claude", "model-context-protocol"],
  "license": "MIT"
}
